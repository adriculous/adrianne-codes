---
const links = [
  { href: "/projects", label: "🧰 Projects" },
  { href: "/tuts", label: "📝 Tuts" },
  { href: "/learn", label: "🌱 Learn" },
  { href: "/about", label: "💙 About" },
  { href: "https://adrianne.io/credentials", label: "🏅 Credentials" },
  { href: "/contact", label: "✉️ Contact" }
];
---

<aside class="sidebar-card" aria-label="Site navigation">
  <a class="brand" href="/" aria-label="Adrianne Codes home">
    <img src="/adrianne-codes-logo.svg" alt="Adrianne Codes Logo" width="140" height="140" loading="eager" />
    <div class="brand-copy">
      <span>Code, clarity, and curiosity</span>
    </div>
  </a>

  <nav class="sidebar-nav" aria-label="Primary">
    <ul class="nav-links">
      {links.map((item) => (
        <li>
          <a 
            href={item.href} 
            target={item.href.startsWith("http") ? "_blank" : undefined}
            rel={item.href.startsWith("http") ? "noopener noreferrer" : undefined}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>

</aside>

<style>
  .sidebar-card {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 0.5rem;
    padding: 2rem 1.75rem;
    border-radius: 2rem;
    background: var(--sidebar-bg);
    border: 1px solid rgba(120, 140, 180, 0.08);
    box-shadow: 0 12px 30px rgba(80, 100, 140, 0.08);
  }

  .brand,
  .brand:visited,
  .brand:hover,
  .brand:focus {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
    text-decoration: none;
    color: var(--ink);
  }

  .brand img {
    display: block;
    width: 140px;
    height: auto;
  }

  .brand-copy {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .brand-copy span {
    display: block;
    max-width: 18ch;
    margin-inline: auto;
    font-size: 0.88rem;
    line-height: 1.5;
    letter-spacing: 0.01em;
    text-transform: none;
    color: rgba(53, 71, 102, 0.9);
    font-weight: 500;
  }

  .sidebar-nav {
    display: block;
    width: 100%;
    min-width: 0;
  }

  .sidebar-nav .nav-links {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    width: 100%;
    gap: 0.55rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .sidebar-nav .nav-links li {
    width: 100%;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .sidebar-nav .nav-links a,
  .sidebar-nav .nav-links a:visited {
    display: block;
    width: 100%;
    padding: 0.78rem 0.95rem;
    border-radius: 999px;
    text-decoration: none;
    text-align: left;
    white-space: nowrap;
    color: #224a86;
    background: transparent;
    border: 1px solid transparent;
    box-shadow: none;
    font-weight: 600;
    font-size: 0.96rem;
    line-height: 1.2;
    letter-spacing: 0.01em;
    transition:
      background-color 0.2s ease,
      color 0.2s ease,
      transform 0.2s ease,
      opacity 0.2s ease,
      box-shadow 0.2s ease;
  }

  .sidebar-nav .nav-links a:hover,
  .sidebar-nav .nav-links a:focus-visible {
    background: rgba(151, 182, 255, 0.22);
    border-color: rgba(90, 127, 224, 0.28);
    color: #5a7fe0;
    transform: translateX(4px);
    opacity: 1;
    box-shadow: 0 8px 18px rgba(90, 127, 224, 0.08);
    outline: none;
  }

  .sidebar-nav .nav-links a[aria-current="page"] {
    color: #18345f;
    background: transparent;
    border-color: transparent;
    box-shadow: none;
  }

  .nav-cta,
  .nav-cta:visited,
  .nav-cta:hover,
  .nav-cta:focus {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    text-decoration: none;
    padding: 0.85rem 1.2rem;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--accent), var(--petal));
    color: var(--midnight);
    font-weight: 700;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.6);
  }

  @media (max-width: 900px) {
    .sidebar-card {
      gap: 1.25rem;
    }

    .brand,
    .brand:visited,
    .brand:hover,
    .brand:focus {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 0.85rem;
    }

    .brand img {
      width: 96px;
    }

    .brand-copy span {
      max-width: 20ch;
      margin-inline: auto;
      font-size: 0.82rem;
      line-height: 1.4;
    }

    .sidebar-nav .nav-links {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      align-items: center;
      width: 100%;
      gap: 0.75rem;
    }

    .sidebar-nav .nav-links a,
    .sidebar-nav .nav-links a:visited {
      width: auto;
      white-space: nowrap;
      text-align: center;
      padding: 0.68rem 0.95rem;
      font-size: 0.92rem;
    }

    .nav-cta,
    .nav-cta:visited,
    .nav-cta:hover,
    .nav-cta:focus {
      width: auto;
      align-self: center;
      min-width: 11rem;
    }
  }
</style>