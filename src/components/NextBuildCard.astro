

---
interface Props {
  title: string;
  description: string;
  status?: string;
  tone?: 'peach' | 'default';
}

const {
  title,
  description,
  status = 'Coming Soon',
  tone = 'peach'
} = Astro.props;
---

<article class:list={["next-build-card", `next-build-card--${tone}`]}>
  {status && <p class="next-build-status">{status}</p>}

  <h3>{title}</h3>
  <p>{description}</p>
</article>

<style>
  .next-build-card {
    width: 100%;
    max-width: 720px;
    margin: 0 auto;
    padding: 1.5rem 1.6rem;
    border-radius: 1.6rem;
    border: 1px solid rgba(120, 140, 180, 0.12);
    box-shadow: 0 16px 32px rgba(80, 100, 140, 0.10);
    backdrop-filter: blur(3px);
  }

  .next-build-card--peach {
    background: linear-gradient(
      135deg,
      rgba(255, 235, 225, 0.95),
      rgba(255, 210, 190, 0.95)
    );
    border-top: 3px solid rgba(255, 150, 120, 0.8);
  }

  .next-build-card--default {
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.96),
      rgba(248, 245, 240, 0.96)
    );
    border: 1px solid rgba(180, 160, 130, 0.25);
  }

  .next-build-status {
    margin: 0 0 0.35rem 0;
    font-size: 0.6rem;
    line-height: 1.2;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #c93f3f;
    opacity: 0.85;
  }

  .next-build-card h3 {
    margin: 0 0 0.7rem 0;
    font-size: 1.45rem;
    line-height: 1.15;
    color: var(--midnight);
  }

  .next-build-card p:not(.next-build-status) {
    margin: 0;
    font-size: 1rem;
    line-height: 1.65;
    color: rgba(40, 55, 85, 0.9);
}
</style>