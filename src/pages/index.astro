---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import NextBuildCard from "../components/NextBuildCard.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
  <div class="site-shell">
    <aside class="site-sidebar">
      <Nav />
    </aside>

    <main class="site-main">
      <section class="hero">
        <p class="eyebrow">Adrianne Codes • Frontend • Writing What I Learn</p>
        <h1>I build useful things and explain them clearly.</h1>
        <p class="hero-copy">
          I’m <strong>Adrianne</strong>, a curious builder who uses this space to share frontend projects, technical writing, coding notes, and the lessons I learn while building in public.
        </p>
      </section>

      <section class="intro-grid" aria-label="What you'll find here">
        <a href="/projects" class="info-card info-card-link">
          <h2>🧰 Projects</h2>
          <p>
            Front-end builds, UI experiments, and portfolio work in progress.
          </p>
        </a>

        <a href="/tuts" class="info-card info-card-link">
          <h2>📝 Tuts</h2>
          <p>
            Tutorials, coding notes, and technical writing that explain things clearly.
          </p>
        </a>

        <a href="/learn" class="info-card info-card-link">
          <h2>🌱 Learn</h2>
          <p>
            Writing while learning as I build with new tools, frameworks, and more.
          </p>
        </a>
      </section>

      <section class="featured-projects">
        <div class="section-heading">
          <p class="eyebrow">Up Next</p>
          <h2>What I’m building next</h2>
        </div>

        <div class="project-grid">
          <NextBuildCard
            title="🍴 Forks"
            description="A playground for small builds, experiments, and mini tools — where I learn by making and documenting along the way."
            status="Coming Soon"
            tone="peach"
          />
        </div>
      </section>
    </main>
  </div>
  <Footer />
</Layout>

<style>
.site-shell {
  display: grid;
  grid-template-columns: 340px 1fr;
  gap: 1.25rem;

  max-width: 1200px;
  margin: 0 auto;
  padding: 1.25rem;

  align-items: start;
}

.site-sidebar {
  position: sticky;
  top: 1rem;
}

.site-main {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.hero {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.eyebrow {
  margin: 0;
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--accent-strong);
}

.hero h1 {
  margin: 0;
  max-width: 16ch;
  font-family: "Fraunces", Georgia, serif;
  font-size: clamp(2.2rem, 4vw, 3.6rem);
  line-height: 1.05;
  color: var(--midnight);
}

.hero-copy {
  margin: 0;
  max-width: 58ch;
  font-size: 1.05rem;
  line-height: 1.75;
  color: var(--slate);
}

.intro-grid,
.project-grid {
  display: grid;
  gap: 1rem;
}

.intro-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.project-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
  justify-items: center;
}

.info-card {
  padding: 1.2rem 1.15rem;
  border-radius: 1.5rem;
  background: rgba(255, 255, 255, 0.62);
  border: 1px solid rgba(120, 140, 180, 0.12);
  box-shadow: 0 12px 24px rgba(80, 100, 140, 0.06);
  backdrop-filter: blur(3px);
}

.info-card h2,
.section-heading h2 {
  margin: 0 0 0.65rem 0;
  color: var(--midnight);
}

.info-card h2 {
  font-size: 1.3rem;
  font-weight: 800;
  line-height: 1.15;
}

.info-card p {
  margin: 0;
  color: rgba(40, 55, 85, 0.9);
  font-size: 0.98rem;
  line-height: 1.65;
  max-width: 18ch;
}

.info-card-link,
.info-card-link:visited {
  text-decoration: none;
  color: inherit;
}

.info-card-link:hover,
.info-card-link:focus-visible {
  text-decoration: none;
  transform: translateY(-4px);
  box-shadow: 0 18px 30px rgba(80, 100, 140, 0.14);
  outline: none;
}

/* 👇 THIS is the important part */
.info-card-link * {
  text-decoration: none;
}

.info-card-link {
  cursor: pointer;
}

.intro-grid .info-card:nth-child(1) {
  background: linear-gradient(135deg, rgba(190, 210, 255, 0.85), rgba(160, 185, 240, 0.85));
}

.intro-grid .info-card:nth-child(2) {
  background: linear-gradient(135deg, rgba(220, 205, 255, 0.85), rgba(190, 170, 240, 0.85));
}

.intro-grid .info-card:nth-child(3) {
  background: linear-gradient(135deg, rgba(205, 235, 220, 0.85), rgba(170, 215, 195, 0.85));
}

.featured-projects {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.section-heading {
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
}

.section-heading h2 {
  font-family: "Fraunces", Georgia, serif;
  font-size: clamp(1.6rem, 3vw, 2.2rem);
  line-height: 1.1;
}

@media (max-width: 900px) {
  .site-shell {
    grid-template-columns: 1fr;
  }

  .site-sidebar {
    position: static;
  }

  .site-footer {
    padding-bottom: 1.5rem;
  }

  .site-footer p {
    text-align: center;
  }
}

.project-grid > * {
  max-width: 420px;
}
</style>
