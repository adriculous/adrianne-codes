---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import { getAllPosts } from "../../lib/client";

const data = await getAllPosts();
const allPosts = data.publication.posts.edges;

const learnPosts = allPosts.filter(({ node }) =>
  node.tags.some((tag) => tag.name.toLowerCase() === "learn")
);
---

<Layout title="Learn | Adrianne Codes">
  <div class="site-shell">
    <aside class="site-sidebar">
      <Nav />
    </aside>

    <main class="site-main">
      <section class="page-header content-shell content-shell--white content-shell--reading">
        <p class="eyebrow">Learn</p>
        <h1>Notes, experiments, and learning in public</h1>
        <p class="page-intro">
          This is where I keep track of what I’m learning — from frontend experiments and AI tools
          to workflow notes, study takeaways, and things I’m figuring out as I go.
        </p>
      </section>

      <section class="learn-list content-shell content-shell--white content-shell--reading">
        <h2>Latest Notes</h2>
        {
          learnPosts.length > 0 ? (
            <ul>
              {learnPosts.map(({ node }) => (
                <li>
                  <a href={`/post/${node.slug}/`}>
                    {node.title}
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <p>No learning notes published yet.</p>
          )
        }
      </section>
    </main>
  </div>

  <Footer />
</Layout>

<style>
  .page-header {
    width: 100%;
  }

  .page-intro {
    margin: 0;
    max-width: 58ch;
    color: var(--slate);
    font-size: 1.02rem;
    line-height: 1.75;
  }

  .learn-empty {
    width: 100%;
  }

  @media (max-width: 900px) {
    .learn-list {
      grid-template-columns: 1fr;
    }
  }

  .learn-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
</style>