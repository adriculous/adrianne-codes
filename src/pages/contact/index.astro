        <p class="contact-note">
          This is a portfolio site, so I’m keeping the contact page simple on purpose.
        </p>
      </section>
    </main>
  </div>

  <Footer />
</Layout>

<style>
  .contact-page {
    width: 100%;
  }

  .contact-list {
    display: grid;
    gap: 0.4rem;
    margin: 1rem 0 1.25rem;
  }

  .contact-list p,
  .contact-note {
    margin: 0;
  }

  .social-link a {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }

  .social-link a:hover {
    transform: translateX(2px);
    transition: 0.15s ease;
  }

  .social-link .icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
  }

  .social-link .icon svg {
    width: 1.35rem;
    height: 1.35rem;
  }
</style>
