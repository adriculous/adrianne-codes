---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getAllPosts, getPost } from '../../lib/client';

export async function getStaticPaths() {
  const data = await getAllPosts();
  const allPosts = data.publication.posts.edges;
  return allPosts.map((post) => {
    return {
      params: { slug: post.node.slug },
    }
  })
}
const { slug } = Astro.params;
const post = await getPost(slug);
---

<Layout title={`${post.title} | Adrianne Codes`}>
  <div class="site-shell">
    <aside class="site-sidebar">
      <Nav />
    </aside>

    <main class="site-main">
      <section class="content-shell content-shell--white content-shell--reading">
        
        {post.coverImage?.url && (
          <img src={post.coverImage.url} alt={post.title} class="post-cover" />
        )}

        <h1>{post.title}</h1>

        <div class="post-meta">
          <span>{post.readTimeInMinutes} min read</span>
        </div>

        <article class="post-content" set:html={post.content.html} />

      </section>
    </main>
  </div>

  <Footer />
</Layout>

<style>
  .post-cover {
    width: 100%;
    border-radius: 0.75rem;
    margin-bottom: 1rem;
  }

  .post-meta {
    margin: 0.5rem 0 1.5rem;
    color: var(--slate);
    font-size: 0.9rem;
  }

  .post-content {
    line-height: 1.75;
  }

  .post-content :global(h2) {
    margin-top: 2rem;
  }

  .post-content :global(img) {
    max-width: 100%;
    border-radius: 0.5rem;
  }
</style>